### 🎭 CREATE ROLES
POST http://localhost:8080/admin/realms/military-lms/roles
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{"name":"super_admin","description":"Super Administrator with full system access","composite":false,"clientRole":false,"containerId":"military-lms"}

###

POST http://localhost:8080/admin/realms/military-lms/roles
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{"name":"admin","description":"Administrator with limited access","composite":false,"clientRole":false,"containerId":"military-lms"}

###

POST http://localhost:8080/admin/realms/military-lms/roles
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{"name":"hr","description":"HR Manager","composite":false,"clientRole":false,"containerId":"military-lms"}

###

POST http://localhost:8080/admin/realms/military-lms/roles
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{"name":"instructor","description":"Instructor/Teacher","composite":false,"clientRole":false,"containerId":"military-lms"}

###

POST http://localhost:8080/admin/realms/military-lms/roles
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{"name":"student","description":"Student","composite":false,"clientRole":false,"containerId":"military-lms"}

###

### 🔐 ASSIGN SUPER ADMIN ROLE TO USER
# First get user ID
GET http://localhost:8080/admin/realms/military-lms/users?username=shareef.hiasat@gmail.com
Authorization: Bearer {{admin_token}}

> {%
  if (response.body && response.body.length > 0) {
    client.global.set("user_id", response.body[0].id);
    client.log("User ID: " + response.body[0].id);
  }
%}

###

# Get role ID
GET http://localhost:8080/admin/realms/military-lms/roles/super_admin
Authorization: Bearer {{admin_token}}

> {%
  if (response.body && response.body.id) {
    client.global.set("super_admin_role_id", response.body.id);
    client.log("Super Admin Role ID: " + response.body.id);
  }
%}

###

# Assign role to user
POST http://localhost:8080/admin/realms/military-lms/users/{{user_id}}/role-mappings/realm
Authorization: Bearer {{admin_token}}
Content-Type: application/json

[{"id":"{{super_admin_role_id}}","name":"super_admin"}]

###

### 🔐 ASSIGN INSTRUCTOR ROLE TO USER
# Get role ID
GET http://localhost:8080/admin/realms/military-lms/roles/instructor
Authorization: Bearer {{admin_token}}

> {%
  if (response.body && response.body.id) {
    client.global.set("instructor_role_id", response.body.id);
    client.log("Instructor Role ID: " + response.body.id);
  }
%}

###

# Assign instructor role to user
POST http://localhost:8080/admin/realms/military-lms/users/{{user_id}}/role-mappings/realm
Authorization: Bearer {{admin_token}}
Content-Type: application/json

[{"id":"{{instructor_role_id}}","name":"instructor"}]

###

### ✅ VERIFY REALM EXISTS
GET http://localhost:8080/realms/military-lms/.well-known/openid-configuration

###

### 🧪 TEST SUPER ADMIN LOGIN
POST http://localhost:8080/realms/military-lms/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&username=shareef.hiasat@gmail.com&password=Test123@&client_id=military-lms-app

> {%
  client.global.set("super_admin_token", response.body.access_token);
  client.log("Super admin token: " + response.body.access_token);
  client.log("Login successful! Token expires in: " + response.body.expires_in + " seconds");
%}

