POST http://localhost:8080/admin/realms/military-lms/users
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "username": "shareef.hiasat@gmail.com",
  "enabled": true,
  "email": "shareef.hiasat@gmail.com",
  "firstName": "Shareef",
  "lastName": "Hiasat",
  "emailVerified": true,
  "credentials": [
    {
      "type": "password",
      "value": "Test123@",
      "temporary": false
    }
  ]
}

