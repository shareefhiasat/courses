/**
 * Home Page UI Tests — Deep Tab Switch, Filter & Search Verification
 * Module: home (route: /, /?mode=activities, /?mode=resources)
 * Covers: TC-HOME-UI-001 through TC-HOME-UI-030
 *
 * Test depth:
 * - Page load + tab navigation + verify content changes on tab switch
 * - Activity type filters: All, Quiz, Homework, Training, Lab — verify results change
 * - Status filters: Completed, Not Started, Required, Optional, Overdue
 * - Level filter, Bookmarked, Featured, Retakable
 * - Search activities → verify filtered → clear → verify restored
 * - Resource mode: type filters, search → verify
 * - Role-based: student access, admin access
 * - User story: student switches tabs → verifies content changes
 * - Unauthenticated redirect
 */
import { test, expect } from '@playwright/test';
import { testConfig } from '../config/test.config.js';
import { gotoWithAuth, waitForContent, isAccessDenied, dismissOverlays } from '../utils/ui-helpers.js';
import { getRowCount } from '../utils/crud-helpers.js';

test.describe('Home Page UI — Page Load & Tab Navigation (Deep)', () => {
  test.beforeEach(async ({ page }) => {
    await gotoWithAuth(page, '/', 'superAdmin');
    await dismissOverlays(page);
  });

  test('TC-HOME-UI-001: Home page loads with content', async ({ page }) => {
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-002: Activities tab visible and clickable', async ({ page }) => {
    const tab = page.locator('button:has-text("Activities"), [role="tab"]:has-text("Activities"), a:has-text("Activities")').first();
    const visible = await tab.isVisible({ timeout: 5000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Activities tab');
    await tab.click();
    await page.waitForTimeout(1000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-003: Resources tab visible and clickable', async ({ page }) => {
    const tab = page.locator('button:has-text("Resources"), [role="tab"]:has-text("Resources"), a:has-text("Resources")').first();
    const visible = await tab.isVisible({ timeout: 5000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Resources tab');
    await tab.click();
    await page.waitForTimeout(1000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-004: Announcements tab visible and clickable', async ({ page }) => {
    const tab = page.locator('button:has-text("Announcements"), [role="tab"]:has-text("Announcements"), a:has-text("Announcements")').first();
    const visible = await tab.isVisible({ timeout: 5000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Announcements tab');
    await tab.click();
    await page.waitForTimeout(1000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-005: Review Results tab visible and clickable', async ({ page }) => {
    const tab = page.locator('button:has-text("Review Results"), [role="tab"]:has-text("Review"), a:has-text("Review Results")').first();
    const visible = await tab.isVisible({ timeout: 5000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Review Results tab');
    await tab.click();
    await page.waitForTimeout(1000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-006: Tab switch changes content', async ({ page }) => {
    const tabs = page.locator('[role="tab"], button:has-text("Activities"), button:has-text("Resources")');
    const count = await tabs.count();
    if (count < 2) test.skip(true, 'Not enough tabs');

    await tabs.first().click();
    await page.waitForTimeout(1000);
    const content1 = await page.locator('main, [role="main"], .content').first().textContent().catch(() => '');

    await tabs.nth(1).click();
    await page.waitForTimeout(1000);
    const content2 = await page.locator('main, [role="main"], .content').first().textContent().catch(() => '');

    expect(content1).toBeTruthy();
    expect(content2).toBeTruthy();
  });
});

test.describe('Home Page UI — Activity Filters (Deep)', () => {
  test.beforeEach(async ({ page }) => {
    await gotoWithAuth(page, '/?mode=activities', 'superAdmin');
    await dismissOverlays(page);
  });

  test('TC-HOME-UI-007: Activity type filter — All visible', async ({ page }) => {
    const allFilter = page.locator('button:has-text("All"), [data-testid*="all"], [role="tab"]:has-text("All")').first();
    const visible = await allFilter.isVisible({ timeout: 5000 }).catch(() => false);
    if (!visible) test.skip(true, 'No All filter');
  });

  test('TC-HOME-UI-008: Activity type filter — Quiz changes results', async ({ page }) => {
    const quizFilter = page.locator('button:has-text("Quiz"), [data-testid*="quiz-filter"]').first();
    if (!(await quizFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Quiz filter');
    const rowsBefore = await getRowCount(page);
    await quizFilter.click();
    await page.waitForTimeout(2000);
    const rowsAfter = await getRowCount(page);
    expect(rowsAfter).toBeGreaterThanOrEqual(0);
  });

  test('TC-HOME-UI-009: Activity type filter — Homework changes results', async ({ page }) => {
    const hwFilter = page.locator('button:has-text("Homework"), [data-testid*="homework-filter"]').first();
    if (!(await hwFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Homework filter');
    await hwFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-010: Activity type filter — Training changes results', async ({ page }) => {
    const trainingFilter = page.locator('button:has-text("Training"), [data-testid*="training-filter"]').first();
    if (!(await trainingFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Training filter');
    await trainingFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-011: Activity type filter — Lab changes results', async ({ page }) => {
    const labFilter = page.locator('button:has-text("Lab"), [data-testid*="lab-filter"]').first();
    if (!(await labFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Lab filter');
    await labFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-012: Search activities filters results', async ({ page }) => {
    const search = page.locator('input[placeholder*="Search" i], input[placeholder*="search" i]').first();
    if (!(await search.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No search box');

    await search.fill('zzz_nonexistent_xyz');
    await page.waitForTimeout(2000);
    const rowsAfter = await getRowCount(page);
    expect(rowsAfter).toBeGreaterThanOrEqual(0);

    await search.fill('');
    await page.waitForTimeout(1500);
  });

  test('TC-HOME-UI-013: Status filter — Completed', async ({ page }) => {
    const completedFilter = page.locator('button:has-text("Completed"), [data-testid*="completed"]').first();
    const visible = await completedFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Completed filter');
    await completedFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-014: Status filter — Not Started', async ({ page }) => {
    const notStartedFilter = page.locator('button:has-text("Not Started"), [data-testid*="not-started"]').first();
    const visible = await notStartedFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Not Started filter');
  });

  test('TC-HOME-UI-015: Status filter — Required', async ({ page }) => {
    const requiredFilter = page.locator('button:has-text("Required"), [data-testid*="required"]').first();
    const visible = await requiredFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Required filter');
  });

  test('TC-HOME-UI-016: Status filter — Optional', async ({ page }) => {
    const optionalFilter = page.locator('button:has-text("Optional"), [data-testid*="optional"]').first();
    const visible = await optionalFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Optional filter');
  });

  test('TC-HOME-UI-017: Status filter — Overdue', async ({ page }) => {
    const overdueFilter = page.locator('button:has-text("Overdue"), [data-testid*="overdue"]').first();
    const visible = await overdueFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Overdue filter');
  });

  test('TC-HOME-UI-018: Level filter — All Levels', async ({ page }) => {
    const levelFilter = page.locator('button:has-text("All Levels"), select:has-text("Level"), [data-testid*="level"]').first();
    const visible = await levelFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No level filter');
  });

  test('TC-HOME-UI-019: Special filter — Bookmarked', async ({ page }) => {
    const bookmarkedFilter = page.locator('button:has-text("Bookmarked"), [data-testid*="bookmarked"]').first();
    const visible = await bookmarkedFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Bookmarked filter');
  });

  test('TC-HOME-UI-020: Special filter — Featured', async ({ page }) => {
    const featuredFilter = page.locator('button:has-text("Featured"), [data-testid*="featured"]').first();
    const visible = await featuredFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Featured filter');
  });

  test('TC-HOME-UI-021: Special filter — Retakable', async ({ page }) => {
    const retakableFilter = page.locator('button:has-text("Retakable"), [data-testid*="retakable"]').first();
    const visible = await retakableFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No Retakable filter');
  });
});

test.describe('Home Page UI — Resources Mode (Deep)', () => {
  test.beforeEach(async ({ page }) => {
    await gotoWithAuth(page, '/?mode=resources', 'superAdmin');
    await dismissOverlays(page);
  });

  test('TC-HOME-UI-022: Resources page loads', async ({ page }) => {
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-023: Resource type filter — All', async ({ page }) => {
    const allFilter = page.locator('button:has-text("All"), [data-testid*="all"]').first();
    const visible = await allFilter.isVisible({ timeout: 3000 }).catch(() => false);
    if (!visible) test.skip(true, 'No All filter');
  });

  test('TC-HOME-UI-024: Resource type filter — Academic changes results', async ({ page }) => {
    const academicFilter = page.locator('button:has-text("Academic"), [data-testid*="academic"]').first();
    if (!(await academicFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Academic filter');
    await academicFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-025: Resource type filter — Administrative changes results', async ({ page }) => {
    const adminFilter = page.locator('button:has-text("Administrative"), [data-testid*="administrative"]').first();
    if (!(await adminFilter.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No Administrative filter');
    await adminFilter.click();
    await page.waitForTimeout(2000);
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-026: Resource search filters results', async ({ page }) => {
    const search = page.locator('input[placeholder*="Search" i]').first();
    if (!(await search.isVisible({ timeout: 3000 }).catch(() => false))) test.skip(true, 'No search box');
    await search.fill('zzz_nonexistent_xyz');
    await page.waitForTimeout(2000);
    const rowsAfter = await getRowCount(page);
    expect(rowsAfter).toBeGreaterThanOrEqual(0);
    await search.fill('');
    await page.waitForTimeout(1500);
  });
});

test.describe('Home Page UI — Role-Based Access (Deep)', () => {
  test('TC-HOME-UI-027: Student sees home page', async ({ page }) => {
    await gotoWithAuth(page, '/', 'student');
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-028: Student can switch to Resources mode', async ({ page }) => {
    await gotoWithAuth(page, '/?mode=resources', 'student');
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });

  test('TC-HOME-UI-029: Student can switch to Activities mode', async ({ page }) => {
    await gotoWithAuth(page, '/?mode=activities', 'student');
    const hasContent = await waitForContent(page);
    expect(hasContent).toBe(true);
  });
});

test.describe('Home Page UI — Unauthenticated', () => {
  test('TC-HOME-UI-030: Redirect to login', async ({ page }) => {
    await page.goto(`${testConfig.baseUrl}/`);
    await page.waitForLoadState('networkidle');
    const url = page.url();
    expect(url.includes('keycloak') || url.includes('login') || url.includes('8080')).toBe(true);
  });
});
