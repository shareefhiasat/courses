{
  "name": "client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "test": "playwright test --config=tests/e2e/playwright.config.js",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:allure": "playwright test --config=tests/e2e/playwright.config.js && pnpm exec allure generate test-results/reports/allure-results -o test-results/reports/allure-report --clean",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest tests/api",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf node_modules pnpm-lock.json && pnpm install",
    "cleanup": "node cleanup.mjs",
    "analyze": "cross-env ANALYZE=true vite build",
    "build:prod": "cross-env NODE_ENV=production vite build",
    "db:generate": "pnpm exec prisma generate --schema prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate dev --schema prisma/schema.prisma",
    "db:reset": "pnpm exec prisma migrate reset --schema prisma/schema.prisma",
    "db:studio": "pnpm exec prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@keycloak/keycloak-admin-client": "^26.5.5",
    "@mui/material": "^7.3.7",
    "@mui/x-data-grid": "^8.25.0",
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^5.22.0",
    "@react-keycloak/web": "^3.4.0",
    "@sentry/react": "^10.25.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cs-learning-hub": "file:..",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.2.7",
    "emoji-picker-react": "^4.16.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^12.23.24",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.0.0",
    "jsqr": "^1.4.0",
    "keycloak-js": "^26.2.3",
    "lucide-react": "^0.577.0",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "playwright": "^1.58.2",
    "prisma": "^5.22.0",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "quill": "^2.0.2",
    "react": "^19.2.3",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-grid-layout": "^1.5.2",
    "react-joyride": "2.9.3",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.9.3",
    "recharts": "^3.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-elasticsearch": "^0.19.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@prisma/extension-optimize": "^2.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "autoprefixer": "^10.4.22",
    "axios": "^1.13.6",
    "babel-jest": "^30.3.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jest": "^30.3.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.1.17",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.4.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom",
        "eslint"
      ]
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "core-js",
      "esbuild",
      "prisma",
      "protobufjs",
      "unrs-resolver"
    ]
  }
}
