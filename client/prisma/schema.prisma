  updatedAt     DateTime       @updatedAt
  announcements Announcement[]
  creator       User?          @relation("PriorityTypesCreator", fields: [createdBy], references: [id])
  updater       User?          @relation("PriorityTypesUpdater", fields: [updatedBy], references: [id])

  @@map("priority_types")
}

model ResourceTypes {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  nameEn      String
  nameAr      String?
  description String?
