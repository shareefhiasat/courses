  creator     User?      @relation("ResourceTypesCreator", fields: [createdBy], references: [id])
  updater     User?      @relation("ResourceTypesUpdater", fields: [updatedBy], references: [id])
  resources   Resource[]

  @@map("resource_types")
}

model CategoryTypes {
  id            Int        @id @default(autoincrement())
  code          String     @unique
  nameEn        String
  nameAr        String?
  descriptionEn String?
  descriptionAr String?
  icon          String?
  color         String?
  sort          Int        @default(0)
  isActive      Boolean    @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  creator       User?      @relation("CategoryTypesCreator", fields: [createdBy], references: [id])
  updater       User?      @relation("CategoryTypesUpdater", fields: [updatedBy], references: [id])
  resources     Resource[]

  @@map("category_types")
}

model User {
  id                             Int                       @id @default(autoincrement())
  email                          String                    @unique
  firstName                      String?
  lastName                       String?
  displayName                    String?
  realName                       String?
  studentNumber                  String?
  sequence                       Int?
  isActive                       Boolean                   @default(true)
  createdBy                      Int?
  updatedBy                      Int?
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  keycloakId                     String?                   @unique
  additionalImageUrl             String?
  militaryIdImageUrl             String?
  profileImageUrl                String?
  qidImageUrl                    String?
  createdAcademicTerms           AcademicTerms[]           @relation("AcademicTermsCreator")
  updatedAcademicTerms           AcademicTerms[]           @relation("AcademicTermsUpdater")
  createdActivities              Activity[]                @relation("ActivityCreator")
  updatedActivities              Activity[]                @relation("ActivityUpdater")
  createdActivityLogActionTypes  ActivityLogActionTypes[]  @relation("ActivityLogActionTypesCreator")
  updatedActivityLogActionTypes  ActivityLogActionTypes[]  @relation("ActivityLogActionTypesUpdater")
  createdActivityTypes           ActivityTypes[]           @relation("ActivityTypesCreator")
  updatedActivityTypes           ActivityTypes[]           @relation("ActivityTypesUpdater")
  createdAnnouncements           Announcement[]            @relation("AnnouncementCreator")
  updatedAnnouncements           Announcement[]            @relation("AnnouncementUpdater")
  createdAssessmentTypes         AssessmentTypes[]         @relation("AssessmentTypesCreator")
  updatedAssessmentTypes         AssessmentTypes[]         @relation("AssessmentTypesUpdater")
  createdAttendanceStatusTypes   AttendanceStatusTypes[]   @relation("AttendanceStatusTypesCreator")
  updatedAttendanceStatusTypes   AttendanceStatusTypes[]   @relation("AttendanceStatusTypesUpdater")
  createdAttendances             Attendance[]              @relation("AttendanceCreator")
  updatedAttendances             Attendance[]              @relation("AttendanceUpdater")
  attendances                    Attendance[]
  createdBehaviorTypes           BehaviorTypes[]           @relation("BehaviorTypesCreator")
  updatedBehaviorTypes           BehaviorTypes[]           @relation("BehaviorTypesUpdater")
  createdBehaviors               Behavior[]                @relation("BehaviorCreator")
  updatedBehaviors               Behavior[]                @relation("BehaviorUpdater")
  behaviors                      Behavior[]
  createdCategoryTypes           CategoryTypes[]           @relation("CategoryTypesCreator")
  updatedCategoryTypes           CategoryTypes[]           @relation("CategoryTypesUpdater")
  createdClasses                 Class[]                   @relation("ClassCreator")
  instructorClasses              Class[]                   @relation("ClassInstructor")
  updatedClasses                 Class[]                   @relation("ClassUpdater")
  createdConfigTypes             ConfigTypes[]             @relation("ConfigTypesCreator")
  updatedConfigTypes             ConfigTypes[]             @relation("ConfigTypesUpdater")
  createdEnrollmentStatusTypes   EnrollmentStatusTypes[]   @relation("EnrollmentStatusTypesCreator")
  updatedEnrollmentStatusTypes   EnrollmentStatusTypes[]   @relation("EnrollmentStatusTypesUpdater")
  createdEnrollments             Enrollment[]              @relation("EnrollmentCreator")
  updatedEnrollments             Enrollment[]              @relation("EnrollmentUpdater")
  enrollments                    Enrollment[]
  createdHelpItems               HelpItems[]               @relation("HelpItemsCreator")
  updatedHelpItems               HelpItems[]               @relation("HelpItemsUpdater")
  createdMarksDistributions      MarksDistribution[]       @relation("MarksDistributionCreator")
  updatedMarksDistributions      MarksDistribution[]       @relation("MarksDistributionUpdater")
  createdParticipationTypes      ParticipationTypes[]      @relation("ParticipationTypesCreator")
  updatedParticipationTypes      ParticipationTypes[]      @relation("ParticipationTypesUpdater")
  createdParticipations          Participation[]           @relation("ParticipationCreator")
  updatedParticipations          Participation[]           @relation("ParticipationUpdater")
  participations                 Participation[]
  createdPenalties               Penalty[]                 @relation("PenaltyCreator")
  updatedPenalties               Penalty[]                 @relation("PenaltyUpdater")
  penalties                      Penalty[]
  createdPenaltyTypes            PenaltyTypes[]            @relation("PenaltyTypesCreator")
  updatedPenaltyTypes            PenaltyTypes[]            @relation("PenaltyTypesUpdater")
  createdPriorityTypes           PriorityTypes[]           @relation("PriorityTypesCreator")
  updatedPriorityTypes           PriorityTypes[]           @relation("PriorityTypesUpdater")
  programsCreated                Program[]                 @relation("ProgramCreator")
  programsUpdated                Program[]                 @relation("ProgramUpdater")
  createdQuestionDifficultyTypes QuestionDifficultyTypes[] @relation("QuestionDifficultyTypesCreator")
  updatedQuestionDifficultyTypes QuestionDifficultyTypes[] @relation("QuestionDifficultyTypesUpdater")
  createdQuestionTypes           QuestionTypes[]           @relation("QuestionTypesCreator")
  updatedQuestionTypes           QuestionTypes[]           @relation("QuestionTypesUpdater")
  createdQuestions               Question[]                @relation("QuestionCreator")
  updatedQuestions               Question[]                @relation("QuestionUpdater")
  quizAttempts                   QuizAttempt[]             @relation("QuizAttemptUser")
  createdQuizStatusTypes         QuizStatusTypes[]         @relation("QuizStatusTypesCreator")
  updatedQuizStatusTypes         QuizStatusTypes[]         @relation("QuizStatusTypesUpdater")
  createdQuizzes                 Quiz[]                    @relation("QuizCreator")
  updatedQuizzes                 Quiz[]                    @relation("QuizUpdater")
  createdRequirementTypes        RequirementTypes[]        @relation("RequirementTypesCreator")
  updatedRequirementTypes        RequirementTypes[]        @relation("RequirementTypesUpdater")
  createdResourceTypes           ResourceTypes[]           @relation("ResourceTypesCreator")
  updatedResourceTypes           ResourceTypes[]           @relation("ResourceTypesUpdater")
  createdResources               Resource[]                @relation("ResourceCreator")
  updatedResources               Resource[]                @relation("ResourceUpdater")
  createdScheduleTypes           ScheduleTypes[]           @relation("ScheduleTypesCreator")
  updatedScheduleTypes           ScheduleTypes[]           @relation("ScheduleTypesUpdater")
  createdStandupAttendances      StandupAttendance[]       @relation("StandupAttendanceCreator")
  updatedStandupAttendances      StandupAttendance[]       @relation("StandupAttendanceUpdater")
  standupAttendances             StandupAttendance[]
  createdStudentMarks            StudentMarks[]            @relation("StudentMarksCreator")
  updatedStudentMarks            StudentMarks[]            @relation("StudentMarksUpdater")
  studentMarks                   StudentMarks[]
  marksHistoryActions            StudentMarksHistory[]     @relation("MarksHistoryActionUser")
  createdSubjectTypes            SubjectTypes[]            @relation("SubjectTypesCreator")
  updatedSubjectTypes            SubjectTypes[]            @relation("SubjectTypesUpdater")
  createdSubjects                Subject[]                 @relation("SubjectCreator")
  updatedSubjects                Subject[]                 @relation("SubjectUpdater")
  createdSubmissionStatusTypes   SubmissionStatusTypes[]   @relation("SubmissionStatusTypesCreator")
  updatedSubmissionStatusTypes   SubmissionStatusTypes[]   @relation("SubmissionStatusTypesUpdater")
  createdSubmissions             Submission[]              @relation("SubmissionCreator")
  updatedSubmissions             Submission[]              @relation("SubmissionUpdater")
  submissions                    Submission[]
  createdTargetAudienceTypes     TargetAudienceTypes[]     @relation("TargetAudienceTypesCreator")
  updatedTargetAudienceTypes     TargetAudienceTypes[]     @relation("TargetAudienceTypesUpdater")
  createdTemplateTypes           TemplateTypes[]           @relation("TemplateTypesCreator")
  updatedTemplateTypes           TemplateTypes[]           @relation("TemplateTypesUpdater")
  createdUserFavorites           UserFavorite[]            @relation("UserFavoriteCreator")
  updatedUserFavorites           UserFavorite[]            @relation("UserFavoriteUpdater")
  userFavorites                  UserFavorite[]            @relation("UserFavorites")
  createdUserPreferences         UserPreferences[]         @relation("UserPreferencesCreator")
  updatedUserPreferences         UserPreferences[]         @relation("UserPreferencesUpdater")
  userPreferences                UserPreferences?          @relation("UserPreferencesUser")
  roleAssignments                UserRoleAssignment[]
  createdUserRoles               UserRoles[]               @relation("UserRolesCreator")
  updatedUserRoles               UserRoles[]               @relation("UserRolesUpdater")
  createdUserStatusTypes         UserStatusTypes[]         @relation("UserStatusTypesCreator")
  updatedUserStatusTypes         UserStatusTypes[]         @relation("UserStatusTypesUpdater")
  filesOwned                     File[]                    @relation("FileOwner")
  fileVersionsUploaded           FileVersion[]             @relation("FileVersionUploader")
  fileComments                   FileComment[]             @relation("FileCommentAuthor")
  fileActivities                 FileActivity[]            @relation("FileActivityActor")
  fileSharesShared               FileShare[]               @relation("FileShareSharer")
  fileSharesReceived             FileShare[]               @relation("FileShareReceiver")

  @@map("users")
}

model Program {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique
  nameEn             String
  nameAr             String?
  descriptionEn      String?
  descriptionAr      String?
  durationYears      Int?
  minGPA             Float?
  totalCreditHours   Int?
  isActive           Boolean             @default(true)
  createdBy          Int
  updatedBy          Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  announcements      Announcement[]
  classes            Class[]
  enrollments        Enrollment[]
  creator            User                @relation("ProgramCreator", fields: [createdBy], references: [id])
  updater            User?               @relation("ProgramUpdater", fields: [updatedBy], references: [id])
  resources          Resource[]
  standupAttendances StandupAttendance[]
  subjects           Subject[]

  @@map("programs")
}

model Subject {
  id                 Int                @id @default(autoincrement())
  code               String             @unique
  nameEn             String
  nameAr             String?
  credits            Int                @default(3)
  isActive           Boolean            @default(true)
  programId          Int
  typeId             Int
  requirementTypeId  Int
  createdBy          Int
  updatedBy          Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  descriptionAr      String?
  descriptionEn      String?
  announcements      Announcement[]
  classes            Class[]
  enrollments        Enrollment[]
  marksDistributions MarksDistribution?
  resources          Resource[]
  studentMarks       StudentMarks[]
  creator            User               @relation("SubjectCreator", fields: [createdBy], references: [id])
  program            Program            @relation(fields: [programId], references: [id])
  requirementType    RequirementTypes   @relation(fields: [requirementTypeId], references: [id])
  subjectType        SubjectTypes       @relation(fields: [typeId], references: [id])
  updater            User?              @relation("SubjectUpdater", fields: [updatedBy], references: [id])

  @@map("subjects")
}

model Class {
  id             Int             @id @default(autoincrement())
  code           String          @unique
  nameEn         String
  nameAr         String?
  maxCapacity    Int?
  isActive       Boolean         @default(true)
  programId      Int
  subjectId      Int
  instructorId   Int?
  createdBy      Int
  updatedBy      Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  descriptionAr  String?
  descriptionEn  String?
  locationAr     String?
  locationEn     String?
  ownerEmail     String?
  term           String?
  year           String?
  activities     Activity[]
  announcements  Announcement[]
  attendances    Attendance[]
  behaviors      Behavior[]
  creator        User            @relation("ClassCreator", fields: [createdBy], references: [id])
  instructor     User?           @relation("ClassInstructor", fields: [instructorId], references: [id])
  program        Program         @relation(fields: [programId], references: [id])
  subject        Subject         @relation(fields: [subjectId], references: [id])
  updater        User?           @relation("ClassUpdater", fields: [updatedBy], references: [id])
  enrollments    Enrollment[]
  participations Participation[]
  penalties      Penalty[]
  resources      Resource[]
  studentMarks   StudentMarks[]

  @@map("classes")
}

model Enrollment {
  id        Int                   @id @default(autoincrement())
  userId    Int
  programId Int
  subjectId Int
  classId   Int
  statusId  Int
  createdBy Int?
  updatedBy Int?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  class     Class                 @relation(fields: [classId], references: [id])
  creator   User?                 @relation("EnrollmentCreator", fields: [createdBy], references: [id])
  program   Program               @relation(fields: [programId], references: [id])
  status    EnrollmentStatusTypes @relation(fields: [statusId], references: [id])
  subject   Subject               @relation(fields: [subjectId], references: [id])
  updater   User?                 @relation("EnrollmentUpdater", fields: [updatedBy], references: [id])
  user      User                  @relation(fields: [userId], references: [id])

  @@unique([userId, classId])
  @@map("enrollments")
}

model Attendance {
  id        Int                   @id @default(autoincrement())
  userId    Int
  classId   Int
  date      DateTime              @default(now())
  statusId  Int
  notes     String?
  createdBy Int?
  updatedBy Int?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  programId Int?
  subjectId Int?
  class     Class                 @relation(fields: [classId], references: [id])
