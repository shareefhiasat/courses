  color       String?
  isActive    Boolean    @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  creator     User?      @relation("BehaviorTypesCreator", fields: [createdBy], references: [id])
  updater     User?      @relation("BehaviorTypesUpdater", fields: [updatedBy], references: [id])
  behaviors   Behavior[]

  @@map("behavior_types")
}

