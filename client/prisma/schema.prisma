// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User model - Firebase-compatible with JSON fields
model User {
  id                          String   @id @default(auto()) @map("_id") @db.ObjectId
  email                       String   @unique
  displayName                 String
  realName                    String?
  passwordHash                String?
  isAdmin                     Boolean  @default(false)
  isSuperAdmin                Boolean  @default(false)
  isInstructor                Boolean  @default(false)
  isStudent                   Boolean  @default(true)
  isHR                        Boolean  @default(false)
  isDisabled                  Boolean  @default(false)
  disabled                    Boolean  @default(false)
  disabledAt                  DateTime?
  disabledBy                  String?  @db.ObjectId
  enabledAt                   DateTime?
  enabledBy                   String?  @db.ObjectId
  status                      String   @default("active")
  phoneNumber                 String?
  studentNumber               String?
  order                       String?
  // Firebase-compatible JSON fields
  enrolledClasses             Json?     // Simple array like Firebase: ["class1", "class2"]
  archivedClasses             Json?     // Simple array like Firebase: ["oldClass1"]
  archivedRooms               Json?     // Simple array like Firebase: ["room1"]
  bookmarks                   Json?     // Nested object like Firebase: { activities: {}, resources: {} }
  chatReads                   Json?     // Simple object like Firebase: { "global": "timestamp" }
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  
  // Relations - Keep only what we need for Categories
  instructedClasses           Class[]   @relation("ClassInstructor")
  uploadedFiles               File[]    @relation("FileUploader")
}

// Class model - Keep only relations needed for Categories
model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nameEn      String
  nameAr      String?
  code        String   @unique
  description String?
  programId   String   @db.ObjectId
  subjectId   String   @db.ObjectId
  instructorId String?  @db.ObjectId
  locationEn  String?
  locationAr  String?
  schedule    Json?     // ClassScheduleSchema - Complex schedule object
  year        String?
  term        String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  program     Program @relation(fields: [programId], references: [id])
  subject     Subject @relation(fields: [subjectId], references: [id])
  instructor  User?    @relation("ClassInstructor", fields: [instructorId], references: [id])
  resources   Resource[]
}

// Program model
model Program {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nameEn      String
  nameAr      String?
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  durationYears Int?    // in years
  minGPA      Float?
  totalCreditHours Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  classes     Class[]
  subjects    Subject[]
  resources   Resource[]
}

// Subject model
model Subject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nameEn      String
  nameAr      String?
  code        String   @unique
  description String?
  credits     Int?
  hoursPerWeek Int?
  totalHours  Int?
  type        String?  // lecture, lab, etc.
  requirementType String? // general_mandatory, elective, etc.
  isActive    Boolean  @default(true)
  programId   String   @db.ObjectId
  classIds    Json?     // SubjectClassesSchema - Array of class IDs with status
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  program     Program @relation(fields: [programId], references: [id])
  classes     Class[]
  resources   Resource[]
}

// Category model - THE MODEL WE'RE MIGRATING
model Category {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  nameEn        String
  nameAr        String?
  icon          String?
  descriptionEn String?
  descriptionAr String?
  color         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  resources    Resource[]
}

// Resource model - Keep only relations needed for Categories
model Resource {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  titleEn     String
  titleAr     String?
  descriptionEn String?
  descriptionAr String?
  type        String
  url         String?
  categoryId  String?  @db.ObjectId
  classId     String?  @db.ObjectId
  programId   String?  @db.ObjectId
  subjectId   String?  @db.ObjectId
  fileId      String?  @db.ObjectId
  featured    Boolean  @default(false)
  optional    Boolean  @default(false)
  dueDate     DateTime?
  createdBy   String?  @db.ObjectId
  updatedBy   String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  category    Category? @relation(fields: [categoryId], references: [id])
  file        File?    @relation(fields: [fileId], references: [id])
  class       Class?   @relation(fields: [classId], references: [id])
  program     Program? @relation(fields: [programId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
}

// File model - Keep only relations needed for Categories
model File {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  originalName String
  mimeType    String
  size        Int
  path        String
  url         String?
  folder      String?
  type        String?  // report, document, etc.
  status      String   @default("active")
  downloads   Int      @default(0)
  lastAccessedAt DateTime?
  accessControl Json?    // FileAccessControlSchema - Access control rules
  uploadedBy  String?  @db.ObjectId
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  uploader    User?    @relation("FileUploader", fields: [uploadedBy], references: [id])
  resources   Resource[]
}

// Config model for system configuration
model Config {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
