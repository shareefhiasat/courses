  updatedAt          DateTime            @updatedAt
  creator            User?               @relation("AttendanceStatusTypesCreator", fields: [createdBy], references: [id])
  updater            User?               @relation("AttendanceStatusTypesUpdater", fields: [updatedBy], references: [id])
  attendances        Attendance[]
  standupAttendances StandupAttendance[]

  @@map("attendance_status_types")
}

