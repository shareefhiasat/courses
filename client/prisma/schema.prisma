  creator     User?      @relation("QuestionCreator", fields: [createdBy], references: [id])
  updater     User?      @relation("QuestionUpdater", fields: [updatedBy], references: [id])

  @@map("questions")
}

model Answer {
  id          Int      @id @default(autoincrement())
  questionId  Int
  quizAttemptId Int
  answer      String   // JSON string for answer data
  isCorrect   Boolean  @default(false)
  points      Float    @default(0)
  createdAt   DateTime @default(now())

  // Relationships
  question    Question    @relation(fields: [questionId], references: [id])
  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id])

  @@map("answers")
}

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  quizId      Int
  userId      Int
  score       Float?
  maxScore    Float?
  percentage  Float?
  passed      Boolean?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  timeSpent   Int?     // Time spent in seconds
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  quiz        Quiz       @relation(fields: [quizId], references: [id])
  user        User       @relation("QuizAttemptUser", fields: [userId], references: [id])
  answers     Answer[]

  @@map("quiz_attempts")
}


