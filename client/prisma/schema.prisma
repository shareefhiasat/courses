  updatedAt       DateTime         @updatedAt
  operations      Operation[]
  rolePermissions RolePermission[]

  @@map("screens")
}

model Operation {
  id              Int              @id @default(autoincrement())
  screenId        Int
  operationKey    String           @unique
  nameEn          String
  nameAr          String?
  descriptionEn   String?
  descriptionAr   String?
  category        String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  screen          Screen           @relation(fields: [screenId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@map("operations")
}

model RolePermission {
  id          Int        @id @default(autoincrement())
  role        String
  screenId    Int
  operationId Int?
  allowed     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  operation   Operation? @relation(fields: [operationId], references: [id], onDelete: Cascade)
  screen      Screen     @relation(fields: [screenId], references: [id], onDelete: Cascade)

  @@unique([role, screenId, operationId])
  @@map("role_permissions")
}

model File {
  id                String          @id @default(uuid())
  s3Key             String          @unique
  bucket            BucketType
  name              String
  mimeType          String
  size              Int
  ownerId           Int
  folderId          String?
  folderPath        String?
  currentVersionId  String?         @unique
  checksumSha256    String?
  workflowStatus    String?         @default("DRAFT") // denormalised workflow instance status code
  publicLinkToken   String?         @unique            // DEPRECATED: migrated to public_links
  publicLinkExpiry  DateTime?                          // DEPRECATED: migrated to public_links
  isActive          Boolean         @default(true)
  isStarred         Boolean         @default(false)
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  deletedById       Int?
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  owner             User            @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  deletedBy         User?           @relation("FileDeleter", fields: [deletedById], references: [id])
  folder            Folder?         @relation("FolderFiles", fields: [folderId], references: [id], onDelete: SetNull)
  currentVersion    FileVersion?    @relation("FileCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions          FileVersion[]   @relation("FileVersions")
  shares            FileShare[]
  publicLinks       PublicLink[]
  comments          FileComment[]
  activities        FileActivity[]
  workflowInstances WorkflowInstance[]
  workflowDocuments WorkflowDocument[] @relation("WorkflowDocumentFile")
  preferences       UserFilePreference[]

  @@index([folderId])
  @@index([ownerId, isDeleted])
  @@index([isDeleted, deletedAt])
  @@map("files")
}

model FileVersion {
  id             String   @id @default(uuid())
  fileId         String
  versionNumber  Int
  s3Key          String   @unique
  size           Int
  uploadedById   Int
  changeNote     String?
  minioVersionId String?
  checksumSha256 String?
  isCurrent      Boolean  @default(false)
  createdAt      DateTime @default(now())

  file           File     @relation("FileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  currentOf      File?    @relation("FileCurrentVersion")
  uploadedBy     User     @relation("FileVersionUploader", fields: [uploadedById], references: [id])

  @@unique([fileId, versionNumber])
  @@index([fileId, isCurrent])
  @@map("file_versions")
}

model FileComment {
  id        String   @id @default(uuid())
  fileId    String
  userId    Int
  content   String
  createdAt DateTime @default(now())

  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation("FileCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@map("file_comments")
}

model FileActivity {
  id        String   @id @default(uuid())
  fileId    String
  userId    Int
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation("FileActivityActor", fields: [userId], references: [id], onDelete: Cascade)

  @@map("file_activities")
}

// ============================================================================
// SmartDrive DMS: folders, ACL, public links, workflow engine
// ============================================================================

model Folder {
  id          String    @id @default(uuid())
  name        String
  parentId    String?
  ownerId     Int
  path        String    // materialised '/a/b/c' for fast prefix lookups
  isPrivate   Boolean   @default(false)
  isStarred   Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderTree")
  owner       User      @relation("FolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  deletedBy   User?     @relation("FolderDeleter", fields: [deletedById], references: [id])
  files       File[]    @relation("FolderFiles")
  shares      FileShare[]
  publicLinks PublicLink[]

  @@unique([parentId, name, ownerId])
  @@index([parentId])
  @@index([ownerId, isDeleted])
  @@map("folders")
}

/// Unified ACL for files AND folders, supporting USER and ROLE subjects.
model FileShare {
  id              String           @id @default(uuid())
  fileId          String?
  folderId        String?
  subjectType     ShareSubjectType
  subjectUserId   Int?
  subjectRole     String?          // Keycloak role code: 'hr','admin', etc.
  permission      SharePermission  @default(VIEW)
  grantedById     Int
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())

  file            File?            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder          Folder?          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  subjectUser     User?            @relation("FileShareUserTarget", fields: [subjectUserId], references: [id], onDelete: Cascade)
  grantedBy       User             @relation("FileShareGrantedBy", fields: [grantedById], references: [id])

  @@index([fileId])
  @@index([folderId])
  @@index([subjectUserId])
  @@index([subjectRole])
  @@map("file_shares")
}

/// Revocable, optionally password-protected tokenised sharing links.
model PublicLink {
  id             String    @id @default(uuid())
  fileId         String?
  folderId       String?
  token          String    @unique
  passwordHash   String?
  maxDownloads   Int?
  downloadCount  Int       @default(0)
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdById    Int
  createdAt      DateTime  @default(now())

  file           File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder         Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdBy      User      @relation("PublicLinkCreator", fields: [createdById], references: [id])

  @@index([fileId])
  @@index([folderId])
  @@map("public_links")
}

/// Per-user UI preferences for files (stars & pins across owners).
model UserFilePreference {
  userId   Int
  fileId   String
  starred  Boolean  @default(false)
  pinned   Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file     File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([userId, fileId])
  @@map("user_file_preferences")
}

// ---------- Generic Workflow Engine ----------

/// A kind of workflow (Attendance Report, Leave Request, HR Audit, ...).
model WorkflowDefinition {
  id          String   @id @default(uuid())
  code        String   @unique      // 'ATTENDANCE_REPORT'
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages      WorkflowStage[]
  instances   WorkflowInstance[]

  @@map("workflow_definitions")
}

/// Ordered stages of a workflow definition.
model WorkflowStage {
  id                   String   @id @default(uuid())
  definitionId         String
  stageOrder           Int
  code                 String              // 'HR_REVIEW'
  name                 String
  assignedRole         String              // Keycloak role code
  allowedActions       String[]            // {'APPROVE','REJECT','REQUEST_CHANGES','SUBMIT'}
  onApproveGoto        Int?                // stage_order to jump to on approve (null = advance)
  onRejectGoto         Int?                // stage_order to jump to on reject (null = terminate)
  isTerminalApproved   Boolean  @default(false)
  slaHours             Int?

  definition           WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  instancesAtStage     WorkflowInstance[] @relation("CurrentStage")
  steps                WorkflowStep[]

  @@unique([definitionId, stageOrder])
  @@unique([definitionId, code])
  @@map("workflow_stages")
}

/// A running workflow attached (optionally) to a File.
model WorkflowInstance {
  id             String                  @id @default(uuid())
  definitionId   String
  fileId         String?
  context        Json                    @default("{}")  // {termId, classId, ...} free-form
  status         WorkflowInstanceStatus  @default(DRAFT)
  currentStageId String?
  assignedUserId Int?                     // Direct user assignment
  assignedRole   String?                  // Role-based assignment
  rejectionReason String?                // Store rejection reason
  revisionCount  Int     @default(0)      // Track revision cycles
  lastRevisedAt  DateTime?               // Last revision timestamp
  initiatedById  Int
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id])
  file           File?              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  currentStage   WorkflowStage?     @relation("CurrentStage", fields: [currentStageId], references: [id])
  initiatedBy    User               @relation("WorkflowInstanceInitiator", fields: [initiatedById], references: [id])
  assignedUser   User?              @relation("WorkflowInstanceAssignedUser", fields: [assignedUserId], references: [id])
  steps          WorkflowStep[]
  history        WorkflowHistory[]

  @@index([status])
  @@index([fileId])
  @@index([currentStageId])
  @@index([initiatedById])
  @@index([assignedUserId])
  @@map("workflow_instances")
}

/// One row per time a stage is entered (including re-entries on rejection).
model WorkflowStep {
  id              String             @id @default(uuid())
  instanceId      String
  stageId         String
  assignedUserId  Int?               // specific user override (nullable)
  assignedRole    String
  status          WorkflowStepStatus @default(PENDING)
  actionTaken     String?            // APPROVE | REJECT | ...
  comments        String?
  actedById       Int?
  enteredAt       DateTime           @default(now())
  completedAt     DateTime?
  dueAt           DateTime?

  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stage           WorkflowStage    @relation(fields: [stageId], references: [id])
  assignedUser    User?            @relation("WorkflowStepAssignee", fields: [assignedUserId], references: [id])
  actedBy         User?            @relation("WorkflowStepActor", fields: [actedById], references: [id])
  history         WorkflowHistory[]

  @@index([instanceId])
  @@index([assignedUserId, status])
  @@index([assignedRole, status])
  @@map("workflow_steps")
}

/// Immutable audit trail of every workflow event.
model WorkflowHistory {
  id          BigInt   @id @default(autoincrement())
  instanceId  String
  stepId      String?
  eventType   String   // INITIATED | STAGE_ENTERED | APPROVED | REJECTED | REVISED | FILE_VERSIONED | CANCELLED
  payload     Json     @default("{}")
  comment     String?  // Optional comment for action
  actorId     Int?
  createdAt   DateTime @default(now())

  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step        WorkflowStep?    @relation(fields: [stepId], references: [id])
  actor       User?            @relation("WorkflowHistoryActor", fields: [actorId], references: [id])

  @@index([instanceId, createdAt])
  @@map("workflow_history")
}

// ============================================================================
// Notification System
// ============================================================================

model Notification {
  id         String               @id @default(uuid())
  userId     Int
  category   NotificationCategory
  event      String               // e.g. 'workflow.assigned', 'announcement.posted'
  priority   NotificationPriority @default(NORMAL)
  titleEn    String
  titleAr    String?
  bodyEn     String
  bodyAr     String?
  link       String?              // deep-link path
  metadata   Json                 @default("{}")  // {classId, subjectId, ...}
  isRead     Boolean              @default(false)
  readAt     DateTime?
  isArchived Boolean              @default(false)
  archivedAt DateTime?
  groupKey   String?              // dedupe key within short window
  createdById Int?
  createdAt  DateTime             @default(now())

  user       User                 @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  creator    User?                @relation("NotificationCreator", fields: [createdById], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, isRead, isArchived, createdAt])
  @@index([userId, category, createdAt])
  @@index([event, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String   @id @default(uuid())
  notificationId String
  channel        String   // 'in_app' | 'email' | 'sms' | 'push'
  status         String   // 'queued' | 'sent' | 'delivered' | 'failed' | 'skipped'
  providerMsgId  String?
  error          String?
  attempts       Int      @default(0)
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, channel])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  // master toggles
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)
  pushEnabled  Boolean @default(false)
  // matrix: { [category]: { in_app, email, sms, push } }
  matrix       Json    @default("{}")
  // browser-side UX prefs (migrated from localStorage/useNotifications)
  soundEnabled       Boolean @default(true)
  vibrationEnabled   Boolean @default(true)
  browserNotifEnabled Boolean @default(true)
  updatedAt    DateTime @updatedAt

  user         User @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============================================================================
// SCHEDULING MODULE MODELS
// ============================================================================

model Classroom {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  nameEn        String
  nameAr        String?
  locationEn    String?
  locationAr    String?
  capacity      Int
  floor         String?
  roomNumber    String?
  equipment     String[] // ["Projector", "Whiteboard", "Computers", etc.]
  availableDays String[] // ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]
  status        String   @default("Available") // Available, UnderMaintenance, Closed
  isActive      Boolean  @default(true)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scheduleSessions     ScheduleSession[] @relation("ClassroomScheduleSessions")
  adminScopes          AdminScope[]     @relation("ClassroomAdminScope")
  flexibleSessions     FlexibleScheduleSession[] @relation("FlexibleClassroomSessions")
  breakSessions        BreakSession[]            @relation("ClassroomBreakSessions")
  classroomAvailability ClassroomAvailability[] @relation("ClassroomAvailability")
  defaultForClasses    Class[]          @relation("ClassDefaultClassroom")
  scheduledSessions    ScheduledSession[] @relation("ScheduledSessionClassroom")
  sessionSeries        SessionSeries[]  @relation("ClassroomSessionSeries")
  creator              User?            @relation("ClassroomCreator", fields: [createdBy], references: [id])
  updater              User?            @relation("ClassroomUpdater", fields: [updatedBy], references: [id])

  @@map("classrooms")
}

model TimeSlot {
  id              Int      @id @default(autoincrement())
  programId       Int
  labelEn         String
  labelAr         String?
  startTime       String   // "09:00"
  endTime         String   // "09:50"
  durationMinutes Int
  isBreak         Boolean  @default(false)
  breakType       String?  // "TeaBreak", "PrayerBreak", "LunchBreak"
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  program         Program          @relation("SchedulingTimeSlots", fields: [programId], references: [id])
  scheduleSessions ScheduleSession[] @relation("TimeSlotScheduleSessions")
  flexibleSessions FlexibleScheduleSession[] @relation("FlexibleTimeSlotSessions")
  breakSessions    BreakSession[]            @relation("TimeSlotBreakSessions")

  @@unique([programId, sortOrder])
  @@map("time_slots")
}

model BreakSession {
  id                Int      @id @default(autoincrement())
  programId         Int
  instructorUserId  Int?
  classroomId       Int?
  timeSlotId        Int
  date              DateTime
  breakType         String   // TeaBreak, PrayerBreak, LunchBreak, Other
  descriptionEn     String?
  descriptionAr     String?
  notes             String?
  isRecurring       Boolean  @default(false)
  recurrencePattern String?
  seriesId          String?  // UUID grouping recurring instances
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  program    Program    @relation("ProgramBreakSessions", fields: [programId], references: [id])
  instructor User?      @relation("InstructorBreakSessions", fields: [instructorUserId], references: [id])
  classroom  Classroom? @relation("ClassroomBreakSessions", fields: [classroomId], references: [id])
  timeSlot   TimeSlot   @relation("TimeSlotBreakSessions", fields: [timeSlotId], references: [id])

  @@unique([timeSlotId, date, instructorUserId, classroomId])
  @@index([date])
  @@index([seriesId])
  @@index([instructorUserId, date])
  @@index([classroomId, date])
  @@map("break_sessions")
}

model Holiday {
  id                Int      @id @default(autoincrement())
  programId         Int?     // null = global default
  descriptionEn     String
  descriptionAr     String?
  type              String   // Public, National, SemesterBreak, Summer, Winter, Other
  startDate         DateTime
  endDate           DateTime
  isRecurring       Boolean  @default(false)
  recurrencePattern String?  // "yearly", "monthly", etc.
  seriesId          String?  // UUID grouping recurring instances
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  program           Program?  @relation("SchedulingHolidays", fields: [programId], references: [id])

  @@index([startDate, endDate])
  @@index([seriesId])
  @@map("holidays")
}

model TeacherAvailability {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  availableDays     String[] // ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]
  maxSessionsPerDay Int      @default(3)
  status            String   @default("Active") // Active, OnLeave, Inactive
  contactPhone      String?
  contactEmail      String?
  notes             String?
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User             @relation("TeacherAvailability", fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_availability")
}

model ScheduleSession {
  id                Int      @id @default(autoincrement())
  classId           Int
  subjectId         Int
  instructorUserId  Int
  classroomId       Int?
  timeSlotId        Int
  date              DateTime
  notes             String?
  isCancelled       Boolean  @default(false)
  cancelledAt       DateTime?
  cancelReason      String?
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  class             Class             @relation("ClassScheduleSessions", fields: [classId], references: [id])
  subject           Subject           @relation("SubjectScheduleSessions", fields: [subjectId], references: [id])
  instructor        User              @relation("InstructorScheduleSessions", fields: [instructorUserId], references: [id])
  classroom         Classroom?        @relation("ClassroomScheduleSessions", fields: [classroomId], references: [id])
  timeSlot          TimeSlot          @relation("TimeSlotScheduleSessions", fields: [timeSlotId], references: [id])

  @@index([date])
  @@index([instructorUserId, date])
  @@index([classroomId, date])
  @@unique([classId, timeSlotId, date])
  @@map("schedule_sessions")
}

// ============================================================================
// Workflow Document System
// ============================================================================

model WorkflowDocument {
  id                  Int                 @id @default(autoincrement())
  workflowType        WorkflowType
  title               String
  description         String?
  status              WorkflowDocumentStatus @default(DRAFT)
  fileId              String?              // Reference to File model (UUID)
  fileVersionId       String?              // Reference to specific FileVersion (UUID) - tracks exact version used
  submitterId         Int
  currentAssigneeId   Int?
  classId             Int?
  instructorId        Int?
  date                DateTime?
  program             String?
  subject             String?
  reviewCycleCount     Int                 @default(0)
  createdBy           Int?
  updatedBy           Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  file                File?                   @relation("WorkflowDocumentFile", fields: [fileId], references: [id], onDelete: SetNull)
  submitter           User                    @relation("WorkflowDocumentSubmitter", fields: [submitterId], references: [id])
  currentAssignee     User?                   @relation("WorkflowDocumentAssignee", fields: [currentAssigneeId], references: [id])
  instructor          User?                   @relation("WorkflowDocumentInstructor", fields: [instructorId], references: [id])
  class               Class?                  @relation("WorkflowDocumentClass", fields: [classId], references: [id])
  comments            WorkflowComment[]
  statusHistory       WorkflowStatusHistory[]

  @@index([submitterId])
  @@index([currentAssigneeId])
  @@index([status])
  @@index([workflowType])
  @@index([workflowType, status])
  @@index([date, status])
  @@index([program, subject])
  @@map("workflow_documents")
}

model WorkflowComment {
  id                 Int             @id @default(autoincrement())
  workflowDocumentId Int
  authorId           Int
  comment            String
  action             String?         // e.g., "APPROVED", "REJECTED", "AMENDED", "COMMENT"
  createdAt          DateTime        @default(now())

  workflowDocument   WorkflowDocument @relation(fields: [workflowDocumentId], references: [id], onDelete: Cascade)
  author             User             @relation("WorkflowCommentAuthor", fields: [authorId], references: [id])

  @@index([workflowDocumentId])
  @@index([authorId])
  @@map("workflow_comments")
}

model WorkflowStatusHistory {
  id                 Int                    @id @default(autoincrement())
  workflowDocumentId Int
  fromStatus         WorkflowDocumentStatus?
  toStatus           WorkflowDocumentStatus
  actorId            Int
  reason             String?
  createdAt          DateTime               @default(now())

  workflowDocument   WorkflowDocument       @relation(fields: [workflowDocumentId], references: [id])
  actor              User                   @relation("WorkflowStatusHistoryActor", fields: [actorId], references: [id])

  @@index([workflowDocumentId])
  @@index([actorId])
  @@map("workflow_status_history")
}

model PermissionDenialAudit {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  resource  String
  reason    String
  userRole  String
  createdAt DateTime @default(now())

  user      User     @relation("PermissionDenialAuditUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("permission_denial_audit")
}

model AdminScope {
  id               Int      @id @default(autoincrement())
  userId           Int
  scopeType        String   // PROGRAM, CLASSROOM, INSTRUCTOR
  programId        Int?
  classroomId      Int?
  instructorUserId Int?
  isActive         Boolean  @default(true)
  createdBy        Int
  createdAt        DateTime @default(now())

  user             User             @relation("AdminScopeUser", fields: [userId], references: [id], onDelete: Cascade)
  program          Program?         @relation("ProgramAdminScope", fields: [programId], references: [id])
  classroom        Classroom?       @relation("ClassroomAdminScope", fields: [classroomId], references: [id])
  instructor       User?            @relation("InstructorAdminScope", fields: [instructorUserId], references: [id])

  @@index([userId, scopeType])
  @@map("admin_scopes")
}

// ============================================================================
// Flexible Scheduling System
// ============================================================================

model FlexibleScheduleSession {
  id                Int      @id @default(autoincrement())
  programId         Int
  courseId          Int?     // Optional course/module within program
  subjectId         Int?
  instructorUserId  Int
  classroomId       Int?
  timeSlotId        Int
  date              DateTime
  recurrenceRule    String?  // JSON: {type: 'weekly', days: ['Sun','Mon'], interval: 1}
  isRecurring       Boolean  @default(false)
  parentSessionId   Int?     // For recurring series
  notes             String?
  isCancelled       Boolean  @default(false)
  cancelledAt       DateTime?
  cancelReason      String?
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  program           Program  @relation("FlexibleProgramSessions", fields: [programId], references: [id])
  instructor        User     @relation("FlexibleInstructorSessions", fields: [instructorUserId], references: [id])
  classroom         Classroom? @relation("FlexibleClassroomSessions", fields: [classroomId], references: [id])
  timeSlot          TimeSlot @relation("FlexibleTimeSlotSessions", fields: [timeSlotId], references: [id])
  parentSession     FlexibleScheduleSession? @relation("RecurringSessions", fields: [parentSessionId], references: [id])
  recurringSessions FlexibleScheduleSession[] @relation("RecurringSessions")

  @@index([date])
  @@index([instructorUserId, date])
  @@index([classroomId, date])
  @@index([programId, date])
  @@map("flexible_schedule_sessions")
}

model InstructorAvailability {
  id                Int      @id @default(autoincrement())
  instructorUserId  Int
  dayOfWeek         String[] // ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
  startDate         DateTime // Start date of availability
  endDate           DateTime // End date of availability
  maxSessionsPerDay Int      @default(3)
  maxHoursPerWeek   Int?
  status            String?
  isActive          Boolean  @default(true)
  programId         Int?     // Optional: restrict to specific program
  subjectId         Int?     // Optional: restrict to specific subject
  classId           Int?     // Optional: restrict to specific class
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  instructor        User     @relation("InstructorAvailability", fields: [instructorUserId], references: [id])
  program           Program? @relation("InstructorAvailabilityProgram", fields: [programId], references: [id])
  subject           Subject? @relation("InstructorAvailabilitySubject", fields: [subjectId], references: [id])
  class             Class?   @relation("InstructorAvailabilityClass", fields: [classId], references: [id])
  creator           User?    @relation("InstructorAvailabilityCreator", fields: [createdBy], references: [id])
  updater           User?    @relation("InstructorAvailabilityUpdater", fields: [updatedBy], references: [id])
  slots             InstructorAvailabilitySlot[] @relation("InstructorAvailabilitySlots")

  @@index([instructorUserId, startDate, endDate])
  @@map("instructor_availability")
}

model InstructorAvailabilitySlot {
  id                    Int      @id @default(autoincrement())
  availabilityId        Int
  startTime             String   // HH:mm format (e.g., '09:00')
  endTime               String   // HH:mm format (e.g., '12:00')
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  availability          InstructorAvailability @relation("InstructorAvailabilitySlots", fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("instructor_availability_slot")
}

model ClassroomAvailability {
  id                Int      @id @default(autoincrement())
  classroomId       Int
  dayOfWeek         String[] // Array of days: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
  startDate         DateTime // Start date of availability
  endDate           DateTime // End date of availability
  status            String?
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  classroom         Classroom @relation("ClassroomAvailability", fields: [classroomId], references: [id])
  creator           User?     @relation("ClassroomAvailabilityCreator", fields: [createdBy], references: [id])
  updater           User?     @relation("ClassroomAvailabilityUpdater", fields: [updatedBy], references: [id])
  slots             ClassroomAvailabilitySlot[] @relation("ClassroomAvailabilitySlots")

  @@index([classroomId, startDate, endDate])
  @@map("classroom_availability")
}

model ClassroomAvailabilitySlot {
  id                    Int      @id @default(autoincrement())
  availabilityId        Int
  startTime             String   // HH:mm format (e.g., '09:00')
  endTime               String   // HH:mm format (e.g., '12:00')
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  availability          ClassroomAvailability @relation("ClassroomAvailabilitySlots", fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("classroom_availability_slot")
}

model ScheduledSession {
  id                  Int      @id @default(autoincrement())
  classId             Int      // The class being scheduled
  instructorId        Int?     // Instructor teaching this session (nullable - can override class default)
  classroomId         Int?     // Classroom for this session (nullable - can override class default)
  startDateTime       DateTime // Full date and time when session starts
  endDateTime         DateTime // Full date and time when session ends
  status              String   @default("scheduled") // scheduled, in_progress, completed, cancelled
  notes               String?  // Additional notes for this session
  
  // Recurrence fields
  recurrenceType      String?  // null, 'daily', 'weekly', 'custom'
  recurrenceDays      String[] @default([]) // ['Sun', 'Tue', 'Thu']
  recurrenceEndDate   DateTime? // When recurrence stops
  recurrenceCount     Int?     // Number of occurrences
  isRecurringInstance Boolean  @default(false) // Is this part of a recurring series
  parentSessionId     Int?     // Links to first instance of series
  seriesId            Int?     // Links to SessionSeries for tracking
  recurrenceSeriesId  String?  // UUID for grouping recurring sessions
  
  // Soft delete fields (Story 2)
  deletedAt           DateTime? // When session was soft deleted
  deletedBy           Int?      // Who deleted the session
  deletionReason      String?   // Why session was deleted
  
  // Capacity override fields (Story 4)
  capacityOverridden  Boolean  @default(false) // Was room capacity overridden
  capacityOverrideReason String? // Why capacity was overridden
  
  isActive            Boolean  @default(true)
  createdBy           Int?
  updatedBy           Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  class               Class     @relation("ScheduledSessionClass", fields: [classId], references: [id], onDelete: Cascade)
  instructor          User?     @relation("ScheduledSessionInstructor", fields: [instructorId], references: [id])
  classroom           Classroom? @relation("ScheduledSessionClassroom", fields: [classroomId], references: [id])
  creator             User?     @relation("ScheduledSessionCreator", fields: [createdBy], references: [id])
  updater             User?     @relation("ScheduledSessionUpdater", fields: [updatedBy], references: [id])
  deleter             User?     @relation("ScheduledSessionDeleter", fields: [deletedBy], references: [id])
  parentSession       ScheduledSession? @relation("RecurringSeries", fields: [parentSessionId], references: [id])
  childSessions       ScheduledSession[] @relation("RecurringSeries")
  series              SessionSeries?    @relation("SeriesSessions", fields: [seriesId], references: [id])
  instructorHistory   InstructorAssignmentHistory[]
  notificationLogs    NotificationLog[]

  @@index([classId])
  @@index([instructorId])
  @@index([classroomId])
  @@index([startDateTime, endDateTime])
  @@index([parentSessionId])
  @@index([seriesId])
  @@index([deletedAt])
  @@index([status])
  @@index([recurrenceSeriesId])
  @@map("scheduled_sessions")
}

model SessionSeries {
  id                Int      @id @default(autoincrement())
  name              String   // Descriptive name for the series
  pattern           String   // Human-readable pattern (e.g., "Every Sun, Tue, Thu")
  recurrenceType    String   // 'daily', 'weekly', 'custom'
  recurrenceDays    String[] // ['Sun', 'Tue', 'Thu']
  startDate         DateTime // Series start date
  endDate           DateTime // Series end date
  totalSessions     Int      // Total number of sessions in series
  completedSessions Int      @default(0) // Number of completed sessions
  cancelledSessions Int      @default(0) // Number of cancelled sessions
  classId           Int      // The class this series is for
  instructorId      Int      // The instructor for this series
  classroomId       Int      // The classroom for this series
  status            String   @default("active") // active, completed, cancelled
  isActive          Boolean  @default(true)
  createdBy         Int?
  updatedBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  class             Class              @relation("ClassSessionSeries", fields: [classId], references: [id], onDelete: Cascade)
  instructor        User               @relation("InstructorSessionSeries", fields: [instructorId], references: [id])
  classroom         Classroom          @relation("ClassroomSessionSeries", fields: [classroomId], references: [id])
  creator           User?              @relation("SessionSeriesCreator", fields: [createdBy], references: [id])
  updater           User?              @relation("SessionSeriesUpdater", fields: [updatedBy], references: [id])
  sessions          ScheduledSession[] @relation("SeriesSessions")

  @@index([classId])
  @@index([instructorId])
  @@index([classroomId])
  @@index([startDate, endDate])
  @@map("session_series")
}

// ============================================================================
// PHASE 1: INSTRUCTOR HISTORY & NOTIFICATIONS
// ============================================================================

model InstructorAssignmentHistory {
  id                Int       @id @default(autoincrement())
  classId           Int
  sessionId         Int?
  oldInstructorId   Int?
  newInstructorId   Int?
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  changedBy         Int?
  changedAt         DateTime  @default(now())
  reason            String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  class             Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  session           ScheduledSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  oldInstructor     User?     @relation("OldInstructor", fields: [oldInstructorId], references: [id], onDelete: SetNull)
  newInstructor     User?     @relation("NewInstructor", fields: [newInstructorId], references: [id], onDelete: SetNull)
  changer           User?     @relation("HistoryChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([sessionId])
  @@index([oldInstructorId])
  @@index([newInstructorId])
  @@index([changedAt])
  @@map("instructor_assignment_history")
}

model NotificationLog {
  id              Int       @id @default(autoincrement())
  userId          Int
  type            String    // 'session_created', 'session_updated', 'session_cancelled', 'session_deleted', 'instructor_changed'
  subject         String
  body            String
  sentAt          DateTime  @default(now())
  deliveryStatus  String    @default("sent") // 'sent', 'failed', 'pending'
  sessionId       Int?
  createdAt       DateTime  @default(now())

  user            User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  session         ScheduledSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([sentAt])
  @@index([type])
  @@map("notification_log")
}

model UserCategoryAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  categoryId Int
  roleId     Int?     // Optional: restrict to specific role
  programId  Int?     // Optional: restrict to specific program
  subjectId  Int?     // Optional: restrict to specific subject
  classId    Int?     // Optional: restrict to specific class
  canView    Boolean  @default(true)
  canManage  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdBy  Int?
  updatedBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation("UserCategoryAccess", fields: [userId], references: [id])
  category   CategoryTypes @relation("CategoryUserAccess", fields: [categoryId], references: [id])
  program    Program? @relation("UserCategoryAccessProgram", fields: [programId], references: [id])
  subject    Subject? @relation("UserCategoryAccessSubject", fields: [subjectId], references: [id])
  class      Class?   @relation("UserCategoryAccessClass", fields: [classId], references: [id])
  creator    User?    @relation("UserCategoryAccessCreator", fields: [createdBy], references: [id])
  updater    User?    @relation("UserCategoryAccessUpdater", fields: [updatedBy], references: [id])

  @@unique([userId, categoryId])
  @@map("user_category_access")
}