  @@map("file_activities")
}

// ============================================================================
// SmartDrive DMS: folders, ACL, public links, workflow engine
// ============================================================================

model Folder {
  id          String    @id @default(uuid())
  name        String
  parentId    String?
  ownerId     Int
  path        String    // materialised '/a/b/c' for fast prefix lookups
  isPrivate   Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[]  @relation("FolderTree")
  owner       User      @relation("FolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  deletedBy   User?     @relation("FolderDeleter", fields: [deletedById], references: [id])
  files       File[]    @relation("FolderFiles")
  shares      FileShare[]
  publicLinks PublicLink[]

  @@unique([parentId, name, ownerId])
  @@index([parentId])
  @@index([ownerId, isDeleted])
  @@map("folders")
}

/// Unified ACL for files AND folders, supporting USER and ROLE subjects.
model FileShare {
  id              String           @id @default(uuid())
  fileId          String?
  folderId        String?
  subjectType     ShareSubjectType
  subjectUserId   Int?
  subjectRole     String?          // Keycloak role code: 'hr','admin', etc.
  permission      SharePermission  @default(VIEW)
  grantedById     Int
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())

  file            File?            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder          Folder?          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  subjectUser     User?            @relation("FileShareUserTarget", fields: [subjectUserId], references: [id], onDelete: Cascade)
  grantedBy       User             @relation("FileShareGrantedBy", fields: [grantedById], references: [id])

  @@index([fileId])
  @@index([folderId])
  @@index([subjectUserId])
  @@index([subjectRole])
  @@map("file_shares")
}

/// Revocable, optionally password-protected tokenised sharing links.
model PublicLink {
  id             String    @id @default(uuid())
  fileId         String?
  folderId       String?
  token          String    @unique
  passwordHash   String?
  maxDownloads   Int?
  downloadCount  Int       @default(0)
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdById    Int
  createdAt      DateTime  @default(now())

  file           File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder         Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdBy      User      @relation("PublicLinkCreator", fields: [createdById], references: [id])

  @@index([fileId])
  @@index([folderId])
  @@map("public_links")
}

/// Per-user UI preferences for files (stars & pins across owners).
model UserFilePreference {
  userId   Int
  fileId   String
  starred  Boolean  @default(false)
  pinned   Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file     File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([userId, fileId])
  @@map("user_file_preferences")
}

// ---------- Generic Workflow Engine ----------

/// A kind of workflow (Attendance Report, Leave Request, HR Audit, ...).
model WorkflowDefinition {
  id          String   @id @default(uuid())
  code        String   @unique      // 'ATTENDANCE_REPORT'
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages      WorkflowStage[]
  instances   WorkflowInstance[]

  @@map("workflow_definitions")
}

/// Ordered stages of a workflow definition.
model WorkflowStage {
  id                   String   @id @default(uuid())
  definitionId         String
  stageOrder           Int
  code                 String              // 'HR_REVIEW'
  name                 String
  assignedRole         String              // Keycloak role code
  allowedActions       String[]            // {'APPROVE','REJECT','REQUEST_CHANGES','SUBMIT'}
  onApproveGoto        Int?                // stage_order to jump to on approve (null = advance)
  onRejectGoto         Int?                // stage_order to jump to on reject (null = terminate)
  isTerminalApproved   Boolean  @default(false)
  slaHours             Int?

  definition           WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  instancesAtStage     WorkflowInstance[] @relation("CurrentStage")
  steps                WorkflowStep[]

  @@unique([definitionId, stageOrder])
  @@unique([definitionId, code])
  @@map("workflow_stages")
}

/// A running workflow attached (optionally) to a File.
model WorkflowInstance {
  id             String                  @id @default(uuid())
  definitionId   String
  fileId         String?
  context        Json                    @default("{}")  // {termId, classId, ...} free-form
  status         WorkflowInstanceStatus  @default(PENDING)
  currentStageId String?
  initiatedById  Int
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id])
  file           File?              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  currentStage   WorkflowStage?     @relation("CurrentStage", fields: [currentStageId], references: [id])
  initiatedBy    User               @relation("WorkflowInstanceInitiator", fields: [initiatedById], references: [id])
  steps          WorkflowStep[]
  history        WorkflowHistory[]

  @@index([status])
  @@index([fileId])
  @@index([currentStageId])
  @@index([initiatedById])
  @@map("workflow_instances")
}

/// One row per time a stage is entered (including re-entries on rejection).
model WorkflowStep {
  id              String             @id @default(uuid())
  instanceId      String
  stageId         String
  assignedUserId  Int?               // specific user override (nullable)
  assignedRole    String
  status          WorkflowStepStatus @default(PENDING)
  actionTaken     String?            // APPROVE | REJECT | ...
  comments        String?
  actedById       Int?
  enteredAt       DateTime           @default(now())
  completedAt     DateTime?
  dueAt           DateTime?

  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stage           WorkflowStage    @relation(fields: [stageId], references: [id])
  assignedUser    User?            @relation("WorkflowStepAssignee", fields: [assignedUserId], references: [id])
  actedBy         User?            @relation("WorkflowStepActor", fields: [actedById], references: [id])
  history         WorkflowHistory[]

  @@index([instanceId])
  @@index([assignedUserId, status])
  @@index([assignedRole, status])
  @@map("workflow_steps")
}

/// Immutable audit trail of every workflow event.
model WorkflowHistory {
  id          BigInt   @id @default(autoincrement())
  instanceId  String
  stepId      String?
  eventType   String   // INITIATED | STAGE_ENTERED | APPROVED | REJECTED | REVISED | FILE_VERSIONED | CANCELLED
  payload     Json     @default("{}")
  actorId     Int?
  createdAt   DateTime @default(now())

  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step        WorkflowStep?    @relation(fields: [stepId], references: [id])
  actor       User?            @relation("WorkflowHistoryActor", fields: [actorId], references: [id])

  @@index([instanceId, createdAt])
  @@map("workflow_history")
}

// ============================================================================
// Notification System
// ============================================================================

model Notification {
  id         String               @id @default(uuid())
  userId     Int
  category   NotificationCategory
  event      String               // e.g. 'workflow.assigned', 'announcement.posted'
  priority   NotificationPriority @default(NORMAL)
  titleEn    String
  titleAr    String?
  bodyEn     String
  bodyAr     String?
  link       String?              // deep-link path
  metadata   Json                 @default("{}")  // {classId, subjectId, ...}
  isRead     Boolean              @default(false)
  readAt     DateTime?
  isArchived Boolean              @default(false)
  archivedAt DateTime?
  groupKey   String?              // dedupe key within short window
  createdById Int?
  createdAt  DateTime             @default(now())

  user       User                 @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  creator    User?                @relation("NotificationCreator", fields: [createdById], references: [id])
  deliveries NotificationDelivery[]

  @@index([userId, isRead, isArchived, createdAt])
  @@index([userId, category, createdAt])
  @@index([event, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String   @id @default(uuid())
  notificationId String
  channel        String   // 'in_app' | 'email' | 'sms' | 'push'
  status         String   // 'queued' | 'sent' | 'delivered' | 'failed' | 'skipped'
  providerMsgId  String?
  error          String?
  attempts       Int      @default(0)
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, channel])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  // master toggles
  inAppEnabled Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)
  pushEnabled  Boolean @default(false)
  // matrix: { [category]: { in_app, email, sms, push } }
  matrix       Json    @default("{}")
  // browser-side UX prefs (migrated from localStorage/useNotifications)
  soundEnabled       Boolean @default(true)
  vibrationEnabled   Boolean @default(true)
  browserNotifEnabled Boolean @default(true)
  updatedAt    DateTime @updatedAt

  user         User @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}