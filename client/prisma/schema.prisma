generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserRoles {
  id              Int                  @id @default(autoincrement())
  code            String               @unique
  nameEn          String
  nameAr          String?
  description     String?
  level           Int                  @default(0)
  isActive        Boolean              @default(true)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  roleAssignments UserRoleAssignment[]
  creator         User?                @relation("UserRolesCreator", fields: [createdBy], references: [id])
  updater         User?                @relation("UserRolesUpdater", fields: [updatedBy], references: [id])

  @@map("user_roles")
}

model UserRoleAssignment {
  id         Int       @id @default(autoincrement())
  userId     Int
  roleId     Int
  assignedAt DateTime  @default(now())
  assignedBy Int?
  role       UserRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role_assignments")
}

model UserStatusTypes {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  nameEn      String
  nameAr      String?
  description String?
  isActive    Boolean  @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User?    @relation("UserStatusTypesCreator", fields: [createdBy], references: [id])
  updater     User?    @relation("UserStatusTypesUpdater", fields: [updatedBy], references: [id])

  @@map("user_status_types")
}

model EnrollmentStatusTypes {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  nameEn      String
  nameAr      String?
  description String?
  isActive    Boolean      @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  creator     User?        @relation("EnrollmentStatusTypesCreator", fields: [createdBy], references: [id])
  updater     User?        @relation("EnrollmentStatusTypesUpdater", fields: [updatedBy], references: [id])
  enrollments Enrollment[]

  @@map("enrollment_status_types")
}

model ActivityTypes {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  nameEn      String
  nameAr      String?
  description String?
  icon        String?
  color       String?
  isActive    Boolean    @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
  creator     User?      @relation("ActivityTypesCreator", fields: [createdBy], references: [id])
  updater     User?      @relation("ActivityTypesUpdater", fields: [updatedBy], references: [id])

  @@map("activity_types")
}

enum BucketType {
  PRIVATE
  WORKFLOW
  SHARED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum NotificationCategory {
  SYSTEM
  ACADEMIC
  ATTENDANCE
  ASSESSMENT
  COMMUNICATION
  ANNOUNCEMENT
  WORKFLOW
  FILE
  QR
  BEHAVIOR
}

enum WorkflowStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
}

enum WorkflowDocumentStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  UNDER_HR_REVIEW
  UNDER_ADMIN_REVIEW
  APPROVED
  REJECTED
  AMENDED
}

enum WorkflowType {
  ATTENDANCE_DAILY
  ATTENDANCE_WEEKLY
  GENERAL_HR
  GENERAL_ADMIN
  GENERAL_MIXED_HR_ADMIN
  GENERAL_MIXED_ADMIN_HR
}

enum SharePermission {
  VIEW
  DOWNLOAD
  COMMENT
  EDIT
}

enum ShareSubjectType {
  USER
  ROLE
}

enum WorkflowInstanceStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  COMPLETED
  SKIPPED
}

