model File {
  id                String          @id @default(uuid())
  s3Key             String          @unique
  bucket            BucketType
  name              String
  mimeType          String
  size              Int
  ownerId           Int
  folderId          String?
  folderPath        String?
  currentVersionId  String?         @unique
  checksumSha256    String?
  workflowStatus    String?         @default("DRAFT") // denormalised workflow instance status code
  publicLinkToken   String?         @unique            // DEPRECATED: migrated to public_links
  publicLinkExpiry  DateTime?                          // DEPRECATED: migrated to public_links
  isActive          Boolean         @default(true)
  isStarred         Boolean         @default(false)
  isDeleted         Boolean         @default(false)
  deletedAt         DateTime?
  deletedById       Int?
  searchVector      Unsupported("tsvector")?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  owner             User            @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  deletedBy         User?           @relation("FileDeleter", fields: [deletedById], references: [id])
  folder            Folder?         @relation("FolderFiles", fields: [folderId], references: [id], onDelete: SetNull)
  currentVersion    FileVersion?    @relation("FileCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions          FileVersion[]   @relation("FileVersions")
  shares            FileShare[]
  publicLinks       PublicLink[]
  comments          FileComment[]
  activities        FileActivity[]
  workflowInstances WorkflowInstance[]
  preferences       UserFilePreference[]

  @@index([folderId])
  @@index([ownerId, isDeleted])
  @@index([isDeleted, deletedAt])
  @@map("files")
}

model FileVersion {
