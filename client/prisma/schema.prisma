  file           File     @relation("FileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  currentOf      File?    @relation("FileCurrentVersion")
  uploadedBy     User     @relation("FileVersionUploader", fields: [uploadedById], references: [id])

  @@unique([fileId, versionNumber])
  @@index([fileId, isCurrent])
  @@map("file_versions")
}

