import React, { useState, useEffect } from 'react';
import { NavLink, useLocation } from 'react-router-dom';
import { 
  Home, 
  LayoutDashboard, 
  Users, 
  Calendar, 
  BookOpen, 
  Award, 
  Settings, 
  FileText, 
  BarChart3, 
  HelpCircle,
  ChevronDown,
  ChevronRight,
  LogOut,
  User
} from 'lucide-react';
import { useAuth } from '@contexts/AuthContext';
import { useLang } from '@contexts/LangContext';
import { Badge } from '@ui';
import './SideDrawer.css';

const SideDrawer = ({ 
  isOpen, 
  onClose, 
  isCollapsed = false,
  onToggleCollapse = null
}) => {
  const { user, logout } = useAuth();
  const { t } = useLang();
  const location = useLocation();
  const [expandedSections, setExpandedSections] = useState({});

  // Close on escape key
  useEffect(() => {
    const handleEscape = (e) => {
      if (e.key === 'Escape' && isOpen) {
        onClose();
      }
    };
    document.addEventListener('keydown', handleEscape);
    return () => document.removeEventListener('keydown', handleEscape);
  }, [isOpen, onClose]);

  // Close on route change
  useEffect(() => {
    if (isOpen) {
      onClose();
    }
  }, [location.pathname, isOpen, onClose]);

  const toggleSection = (section) => {
    setExpandedSections(prev => ({
      ...prev,
      [section]: !prev[section]
    }));
  };

  const handleLogout = async () => {
    await logout();
    onClose();
  };

  const mainNavItems = [
    {
      to: '/',
      label: t('home', 'Home'),
      icon: Home,
      badge: null
    },
    {
      to: '/dashboard',
      label: t('dashboard', 'Dashboard'),
      icon: LayoutDashboard,
      badge: null
    }
  ];

  const adminNavItems = [
    {
      section: 'management',
      label: t('management', 'Management'),
      icon: Settings,
      items: [
        { to: '/users', label: t('users', 'Users'), icon: Users },
        { to: '/programs', label: t('programs', 'Programs'), icon: BookOpen },
        { to: '/subjects', label: t('subjects', 'Subjects'), icon: BookOpen },
        { to: '/classes', label: t('classes', 'Classes'), icon: Users },
      ]
    },
    {
      section: 'academic',
      label: t('academic', 'Academic'),
      icon: BookOpen,
      items: [
        { to: '/quizzes', label: t('quizzes', 'Quizzes'), icon: FileText },
        { to: '/question-bank', label: t('question_bank', 'Question Bank'), icon: HelpCircle },
        { to: '/marks-entry', label: t('marks_entry', 'Marks Entry'), icon: BarChart3 },
      ]
    },
    {
      section: 'attendance',
      label: t('attendance', 'Attendance'),
      icon: Calendar,
      items: [
        { to: '/attendance', label: t('attendance_management', 'Attendance Management'), icon: Calendar },
        { to: '/hr-attendance', label: t('hr_attendance', 'HR Attendance'), icon: Calendar },
        { to: '/hr-penalties', label: t('hr_penalties', 'HR Penalties'), icon: FileText },
      ]
    },
    {
      section: 'reports',
      label: t('reports', 'Reports'),
      icon: BarChart3,
      items: [
        { to: '/analytics', label: t('analytics', 'Analytics'), icon: BarChart3 },
        { to: '/advanced-analytics', label: t('advanced_analytics', 'Advanced Analytics'), icon: BarChart3 },
        { to: '/scheduled-reports', label: t('scheduled_reports', 'Scheduled Reports'), icon: FileText },
      ]
    }
  ];

  const userNavItems = [
    {
      to: '/my-enrollments',
      label: t('my_enrollments', 'My Enrollments'),
      icon: BookOpen,
      badge: null
    },
    {
      to: '/student-dashboard',
      label: t('student_dashboard', 'Student Dashboard'),
      icon: LayoutDashboard,
      badge: null
    },
    {
      to: '/profile',
      label: t('profile', 'Profile'),
      icon: User,
      badge: null
    },
    {
      to: '/settings',
      label: t('settings', 'Settings'),
      icon: Settings,
      badge: null
    }
  ];

  const renderNavItem = (item, isSubItem = false) => {
    const isActive = location.pathname === item.to;
    
    return (
      <NavLink
        key={item.to}
        to={item.to}
        className={`side-nav-item ${isSubItem ? 'sub-item' : ''} ${isActive ? 'active' : ''}`}
        onClick={onClose}
      >
        <item.icon size={18} />
        {!isCollapsed && (
          <>
            <span className="nav-label">{item.label}</span>
            {item.badge && <Badge {...item.badge} />}
          </>
        )}
      </NavLink>
    );
  };

  const renderSection = (section) => {
    const isExpanded = expandedSections[section.section];
    
    return (
      <div key={section.section} className="nav-section">
        <button
          className="nav-section-header"
          onClick={() => toggleSection(section.section)}
        >
          <section.icon size={18} />
          {!isCollapsed && (
            <>
              <span className="nav-label">{section.label}</span>
              {isExpanded ? <ChevronDown size={16} /> : <ChevronRight size={16} />}
            </>
          )}
        </button>
        {isExpanded && !isCollapsed && (
          <div className="nav-section-items">
            {section.items.map(renderNavItem)}
          </div>
        )}
      </div>
    );
  };

  if (!isOpen) return null;

  return (
    <>
      {/* Overlay */}
      <div className={`side-drawer-overlay ${isCollapsed ? 'collapsed' : ''}`} onClick={onClose} />
      
      {/* Drawer */}
      <div className={`side-drawer ${isCollapsed ? 'collapsed' : ''}`}>
        {/* Header */}
        <div className="side-drawer-header">
          <div className="header-content">
            <h2 className="drawer-title">
              {isCollapsed ? 'QAF' : t('navigation', 'Navigation')}
            </h2>
            <div className="header-actions">
              {onToggleCollapse && (
                <button
                  className="collapse-btn"
                  onClick={onToggleCollapse}
                  title={isCollapsed ? t('expand_sidebar', 'Expand sidebar') : t('collapse_sidebar', 'Collapse sidebar')}
                >
                  <ChevronRight size={18} className={isCollapsed ? 'rotate-180' : ''} />
                </button>
              )}
              <button
                className="close-btn"
                onClick={onClose}
                title={t('close_sidebar', 'Close sidebar')}
              >
                ×
              </button>
            </div>
          </div>
        </div>

        {/* Navigation */}
        <div className="side-drawer-content">
          <div className="nav-sections">
            {/* Main Navigation */}
            <div className="nav-section">
              {mainNavItems.map(renderNavItem)}
            </div>

            {/* Admin Navigation */}
            {user?.isAdmin && (
              <>
                <div className="nav-divider" />
                {adminNavItems.map(renderSection)}
              </>
            )}

            {/* User Navigation */}
            <div className="nav-divider" />
            {userNavItems.map(renderNavItem)}
          </div>
        </div>

        {/* Footer */}
        {user && !isCollapsed && (
          <div className="side-drawer-footer">
            <div className="user-profile">
              <div className="user-avatar">
                {user.displayName?.[0] || user.email?.[0] || 'U'}
              </div>
              <div className="user-details">
                <div className="user-name">{user.displayName || user.name || 'User'}</div>
                <div className="user-email">{user.email}</div>
              </div>
            </div>
            <button className="logout-btn" onClick={handleLogout}>
              <LogOut size={18} />
              <span>{t('logout', 'Logout')}</span>
            </button>
          </div>
        )}
      </div>
    </>
  );
};

export default SideDrawer;
