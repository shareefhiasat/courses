{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/meta/llama-3.1-8b-instruct",
  "small_model": "nvidia/meta/llama-3.1-8b-instruct",
  "steps": 20,
  "provider": {
    "nvidia": {
      "provider": "openai",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}",
        "timeout": 120000,
        "chunkTimeout": 30000
      },
      "models": {
        "meta/llama-3.1-8b-instruct": {
          "id": "meta/llama-3.1-8b-instruct",
          "limit": {
            "context": 131072,
            "output": 4096
          }
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "docker *": "allow",
      "pnpm *": "allow",
      "npm *": "allow",
      "node *": "allow",
      "npx *": "allow",
      "curl *": "allow",
      "grep *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
