{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia-free/nvidia-nemotron-nano-9b-v2",
  "small_model": "nvidia-free/nvidia-nemotron-nano-9b-v2",
  "provider": {
    "nvidia-free": {
      "provider": "openai",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "nvidia-nemotron-nano-9b-v2": {
          "id": "nvidia/NVIDIA-Nemotron-Nano-9B-v2",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "docker *": "allow",
      "pnpm *": "allow",
      "npm *": "allow",
      "node *": "allow",
      "npx *": "allow",
      "curl *": "allow",
      "grep *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
