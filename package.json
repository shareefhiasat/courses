{
  "name": "cs-learning-hub",
  "version": "1.0.0",
  "description": "Learning Hub",
  "scripts": {
    "dev": "pnpm --filter client run dev",
    "dev:prod": "pnpm --filter client run dev",
    "dev:emulator": "cross-env VITE_USE_EMULATOR=true pnpm --filter client run dev",
    "emulator": "firebase emulators:start --only functions",
    "build": "pnpm --filter client run build",
    "build:prod": "pnpm --filter client run build:prod",
    "preview": "pnpm --filter client run preview",
    "analyze": "pnpm --filter client run analyze",
    "storybook": "pnpm --filter client run storybook",
    "build-storybook": "pnpm --filter client run build-storybook",
    "deploy": "pnpm run build && firebase deploy",
    "deploy:hosting": "pnpm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:all": "pnpm run build && firebase deploy --only hosting,functions,firestore",
    "test": "pnpm --filter client run lint",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.js --ui",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.js --headed",
    "test:e2e:debug": "playwright test --config=tests/e2e/playwright.config.js --debug",
    "test:e2e:smoke": "playwright test --config=tests/e2e/playwright.config.js --grep @smoke",
    "test:e2e:report": "playwright show-report",
    "lint": "pnpm --filter client run lint",
    "lint:fix": "pnpm --filter client run lint -- --fix",
    "setup:env": "powershell -ExecutionPolicy Bypass -File setup-env.ps1",
    "setup:env:unix": "bash setup-env.sh"
  },
  "keywords": [
    "react",
    "firebase",
    "education",
    "learning"
  ],
  "author": "CS Learning Hub Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "cross-env": "^10.1.0",
    "playwright": "^1.57.0"
  }
}
